# Скопируйте в .env: cp .env.example .env

POSTGRES_USER=autello
POSTGRES_PASSWORD=смените_на_длинный_секрет
POSTGRES_DB=autello

# Backend (SQLAlchemy + psycopg v3). В docker-compose задаётся автоматически; для локального запуска uvicorn:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/DB

# JWT для админ-панели (смените на длинный случайный секрет)
JWT_SECRET_KEY=смените_на_длинный_секрет_для_jwt
JWT_EXPIRE_MINUTES=1440

# Должен проходить валидацию pgAdmin 8 (не используйте только .local без настройки — см. compose)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=смените_на_секрет

# Порт HTTP (Nginx)
HTTP_PORT=80

# Registry: порт на хосте для docker login / docker push с вашей машины (слушает 0.0.0.0 — доступ извне)
REGISTRY_PORT=5000

# Публичный хост или IP — подставляйте в команды на локальной машине:
#   docker login REGISTRY_PUBLIC_HOST:REGISTRY_PORT -u <логин_из_htpasswd>
# Логин/пароль не из Docker Hub: их задаётте только вы в registry/auth/htpasswd (init-registry-auth.sh).
REGISTRY_PUBLIC_HOST=your.server.example.com

TZ=Europe/Moscow
